# Copy this file to `.env` and fill in real values. NEVER commit the real `.env`.

# --- Database ---
# Async driver (asyncpg) is required by the app.
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@localhost:5432/assetflow

# --- Auth ---
# Generate a long random string, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
SECRET_KEY=<generate-a-long-random-secret>

# --- Azure OpenAI (AI model-editor agent) ---
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# --- Azure Cognitive Speech (optional, microphone dictation) ---
SPEECH_KEY=<your-azure-speech-key>
SPEECH_ENDPOINT=https://<your-region>.api.cognitive.microsoft.com/

# --- Seed script (optional) ---
# Password used by seed_admin_users.py for the default admin accounts.
SHARED_ADMIN_PASSWORD=<choose-a-strong-password>
